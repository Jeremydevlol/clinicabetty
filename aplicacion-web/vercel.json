{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://clinicabetty-1.onrender.com/api/:path*"
    },
    {
      "source": "/((?!api/|assets/|favicon\\.ico|robots\\.txt|.*\\.(?:js|css|map|json|png|jpg|jpeg|gif|svg|webp|ico|woff2?|ttf|eot|wasm|pdf|mp4|webm)).*)",
      "destination": "/index.html"
    }
  ]
}
